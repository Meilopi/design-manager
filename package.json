{
  "name": "design-manager",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "check:no-workers-dev": "node scripts/check-no-workers-dev.mjs",
    "typecheck": "pnpm -r typecheck",
    "build:dashboard": "pnpm --filter @design-manager/dashboard build",
    "deploy:all": "node scripts/deploy.mjs",
    "deploy:plan": "node scripts/deploy.mjs --plan"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "undici": "^6.21.0"
  }
}
